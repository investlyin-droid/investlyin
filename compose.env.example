# Optional: copy to ".env" in the repository root (same folder as docker-compose.yml).
# Docker Compose loads .env automatically for variable substitution in compose files.
# Do not commit .env — it may contain secrets or deployment-specific URLs.
#
# Used by docker-compose.prod.yml when overriding default API hostnames:

NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
