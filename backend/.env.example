# Server (production)
# PORT=3001
# NODE_ENV=production
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com  (required in production for CORS)

# Admin panel: only these email(s) can access /admin (comma-separated). If unset, any user with role admin can access.
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_ALLOWED_EMAILS=admin@yourdomain.com,ops@yourdomain.com

# MongoDB Configuration (localhost = local dev / Docker Desktop with mongo container exposing 27017)
MONGO_URI=mongodb://admin:securepassword123@localhost:27017/trading?authSource=admin

# Redis Configuration (localhost = local dev / Docker Desktop with redis container exposing 6379)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=securepassword123

# JWT Secret (Change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Firebase (required for auth – token verification needs a service account)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Use ONE of the following for reliable token verification:
# Option A: path to service account JSON file (download from Firebase Console > Project Settings > Service accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/serviceAccountKey.json
# Option B: same as A, standard env var used by Google libraries
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json
# Option C: service account JSON as string (e.g. in CI or PaaS secrets)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...",...}

# News APIs (optional – for real-time news feed)
# MarketAux: https://www.marketaux.com/register
MARKETAUX_API_KEY=your_marketaux_api_token
# NewsAPI: https://newsapi.org
# NEWSAPI_KEY=your_newsapi_key
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Platform Fees (optional, defaults to 0). Withdrawal fee is applied when users submit withdrawal requests.
PLATFORM_DEPOSIT_FEE_PERCENT=0
PLATFORM_WITHDRAWAL_FEE_PERCENT=0
PLATFORM_TRADE_FEE_PERCENT=0

# Payment Configuration
# SumUp Merchant Account API Key (for card payments)
# Get your API key from: https://me.sumup.com/developers
DEPOSIT_CARD_SUMUP_URL=https://checkout.sumup.com/pay?key=YOUR_SUMUP_API_KEY_HERE
# OR use this alternative:
# DEPOSIT_CARD_PAYMENT_URL=https://checkout.sumup.com/pay?key=YOUR_SUMUP_API_KEY_HERE

# Crypto Wallet Addresses (Optional - can also be configured via Admin API)
# These are fallback addresses if not configured in database
DEPOSIT_CRYPTO_POLYGON=0xYourPolygonAddress
DEPOSIT_CRYPTO_BASE=0xYourBaseAddress
DEPOSIT_CRYPTO_BNB=0xYourBNBChainAddress
DEPOSIT_CRYPTO_ARBITRUM=0xYourArbitrumAddress
DEPOSIT_CRYPTO_LINEA=0xYourLineaAddress
DEPOSIT_CRYPTO_ETH=0xYourEthereumAddress
DEPOSIT_CRYPTO_USDT_ERC20=0xYourUSDT_ERC20Address
DEPOSIT_CRYPTO_USDT_TRC20=TYourUSDT_TRC20Address
DEPOSIT_CRYPTO_TRON=TYourTronAddress
DEPOSIT_CRYPTO_BTC=bc1qYourBitcoinAddress
DEPOSIT_CRYPTO_SOLANA=YourSolanaAddress

# Upload directory (optional; default: uploads relative to cwd). KYC and payment screenshots stored under this path.
# UPLOAD_DIR=uploads

# Bank Transfer Details (Optional - for future use)
DEPOSIT_BANK_NAME=Your Company Ltd
DEPOSIT_BANK_IBAN=GB00XXXX00000000000000
DEPOSIT_BANK_SWIFT=XXXXGB2L
DEPOSIT_BANK_REF_LABEL=Payment reference
