# Production deployment config. Copy to deploy.env and set values.
# Usage: ./scripts/deploy.sh --production
# The script sources deploy.env (if present) and uses these variables.

# Your main domain (no https://)
DEPLOY_DOMAIN=yourdomain.com

# API subdomain (default: api.DEPLOY_DOMAIN)
# API_DOMAIN=api.yourdomain.com

# Comma-separated origins for CORS (default: https://DEPLOY_DOMAIN,https://www.DEPLOY_DOMAIN)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
